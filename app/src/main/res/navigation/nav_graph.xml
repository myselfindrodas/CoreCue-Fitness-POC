<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.corecue.fitness.ui.splash.SplashFragment">
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.corecue.fitness.ui.home.HomeFragment">
        <action
            android:id="@+id/action_home_to_calibration"
            app:destination="@id/calibrationFragment" />
    </fragment>

    <fragment
        android:id="@+id/calibrationFragment"
        android:name="com.corecue.fitness.ui.calibration.CalibrationFragment">
        <action
            android:id="@+id/action_calibration_to_demo"
            app:destination="@id/demoVideoFragment" />
        <action
            android:id="@+id/action_calibration_to_recording"
            app:destination="@id/recordingFragment" />
    </fragment>

    <fragment
        android:id="@+id/demoVideoFragment"
        android:name="com.corecue.fitness.ui.demo.DemoVideoFragment">
        <action
            android:id="@+id/action_demo_to_recording"
            app:destination="@id/recordingFragment" />
    </fragment>

    <fragment
        android:id="@+id/recordingFragment"
        android:name="com.corecue.fitness.ui.recording.RecordingFragment">
        <action
            android:id="@+id/action_recording_to_report"
            app:destination="@id/reportFragment" />
    </fragment>

    <fragment
        android:id="@+id/reportFragment"
        android:name="com.corecue.fitness.ui.report.ReportFragment" />

</navigation>
