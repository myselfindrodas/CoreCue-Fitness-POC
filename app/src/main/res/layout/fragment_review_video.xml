<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:show_timeout="3000"
        app:use_controller="true" />

    <LinearLayout
        android:id="@+id/control_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:background="@color/accent_blue"
            android:text="Review recording"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:visibility="gone"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/retake_btn"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="Retake video"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                app:iconGravity="textStart"
                android:minHeight="0dp"
                app:backgroundTint="#5D6B78"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_retake_24"
                app:iconPadding="0dp"
                app:iconTint="@android:color/white"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/submit_btn"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:contentDescription="Submit video"
                android:insetTop="0dp"
                app:iconGravity="textStart"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="#3C7BFF"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_check_24"
                app:iconPadding="0dp"
                app:iconTint="@android:color/white"
                app:strokeWidth="0dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
